@using Practica2Grupo7.BLL.Dtos
@model List<Practica2Grupo7.BLL.Dtos.CategoriaDto>
@{
    ViewData["Title"] = "Gestión de Categorías";
}

<div class="container-fluid py-5" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh;">

    <div class="container col-10">
    <div class="row mb-5">
        <div class="col-lg-10 mx-auto">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <div>
                    <h1 class="display-4 fw-bold text-white mb-2">
                        <i class="fas fa-tags"></i> Gestión de Categorías
                    </h1>
                    <p class="text-white-50 fs-5">Administra todas tus categorías y sus servicios</p>
                </div>
                <button class="btn btn-light btn-lg rounded-pill shadow-lg" data-bs-toggle="modal" data-bs-target="#modalNuevaCategoria">
                    <i class="fas fa-plus"></i> Nueva Categoría
                </button>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-12">

            <div class="card border-0 shadow-sm rounded-4">

                <div class="card-header bg-white border-0 pt-4 pb-2">
                    <div class="d-flex justify-content-between align-items-center">

                        <h5 class="mb-0 fw-semibold">
                            <i class="fas fa-list me-2 text-primary"></i>Listado de categorías
                        </h5>

                    </div>
                </div>

                <div class="card-body pt-2">

                    <div class="table-responsive">

                        <table id="tblCategoria" class="table align-middle table-hover mb-0">

                            <thead class="table-light">
                                <tr>
                                    <th>Nombre</th>
                                    <th>Descripción</th>
                                    <th class="text-center">Acciones</th>
                                </tr>
                            </thead>

                            <tbody></tbody>

                        </table>

                    </div>

                </div>

            </div>

        </div>
    </div>
    @await Html.PartialAsync("_Editar", new CategoriaDto())
    @await Html.PartialAsync("_Crear", new CategoriaDto())
</div>
</div>


@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/Categoria.js"asp-append-version="true"></script>

}
