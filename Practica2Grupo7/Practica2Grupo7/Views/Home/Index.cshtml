@{
    ViewData["Title"] = "Dashboard";
}

<div class="container">

    <div class="text-center mb-4">
        <h1 class="display-4">Sistema Médico</h1>
        <p class="text-muted">Gestión de categorías y productos médicos</p>
    </div>


    <div class="row">

        <div class="col-md-6 mb-3">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center">
                    <i class="fa fa-tags fa-3x text-primary mb-2"></i>
                    <h4>Categorías</h4>
                    <p class="text-muted">Administra las categorías de productos médicos</p>

                    <a href="/Categorias/Index" class="btn btn-primary">
                        Ir a categorías
                    </a>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-3">
            <div class="card shadow-sm border-0">
                <div class="card-body text-center">
                    <i class="fa fa-pills fa-3x text-success mb-2"></i>
                    <h4>Productos</h4>
                    <p class="text-muted">Gestiona el inventario de productos médicos</p>

                    <a href="/Productos/Index" class="btn btn-success">
                        Ir a productos
                    </a>
                </div>
            </div>
        </div>

    </div>

    <div class="row mt-4">

        <div class="col-md-12">
            <div class="alert alert-info text-center">
                <strong>Bienvenido</strong> al sistema de gestión médica.
                Aquí puedes administrar categorías y productos de forma sencilla.
            </div>
        </div>

    </div>

</div>