@using Practica2Grupo7.BLL.Dtos
@model List<Practica2Grupo7.BLL.Dtos.ProductoDto>

@{
    ViewData["Title"] = "Gestión de Productos";
}

<div class="container-fluid py-5" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); min-height: 100vh;">

    <div class="container col-10">
        <div class="row mb-5">
            <div class="col-lg-10 mx-auto">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div>
                        <h1 class="display-4 fw-bold text-white mb-2">
                            <i class="fas fa-pills"></i> Gestión de Productos
                        </h1>
                        <p class="text-white-50 fs-5">Administra todos tus productos médicos</p>
                    </div>

                    <button class="btn btn-light btn-lg rounded-pill shadow-lg" data-bs-toggle="modal" data-bs-target="#modalNuevoProducto">
                        <i class="fas fa-plus"></i> Nuevo Producto
                    </button>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-12">

                <div class="card border-0 shadow-sm rounded-4">

                    <div class="card-header bg-white border-0 pt-4 pb-2">
                        <h5 class="mb-0 fw-semibold">
                            <i class="fas fa-list me-2 text-primary"></i>Listado de productos
                        </h5>
                    </div>

                    <div class="card-body pt-2">
                        <div class="table-responsive">

                            <table id="tblProducto" class="table align-middle table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>Nombre</th>
                                        <th>Descripción</th>
                                        <th>Precio</th>
                                        <th>Stock</th>
                                        <th>Categoría</th>
                                        <th class="text-center">Acciones</th>
                                    </tr>
                                </thead>

                                <tbody></tbody>
                            </table>

                        </div>
                    </div>

                </div>

            </div>
        </div>

        @await Html.PartialAsync("_Editar", new ProductoDto())
        @await Html.PartialAsync("_Crear", new ProductoDto())

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script src="~/js/Producto.js" asp-append-version="true"></script>
}